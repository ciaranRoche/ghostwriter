// OpenCode MCP configuration
// Merge this into your ~/.config/opencode/opencode.json under the "mcp" key.
//
// Example:
// {
//   "$schema": "https://opencode.ai/config.json",
//   ...your existing config...
//   "mcp": {
//     "writing-samples": { ...this block... }
//   }
// }
{
  "writing-samples": {
    "type": "local",
    "command": [
      "mcp-server-qdrant"
    ],
    "environment": {
      "QDRANT_URL": "http://127.0.0.1:6333",
      "COLLECTION_NAME": "writing-samples",
      "TOOL_STORE_DESCRIPTION": "Store a writing sample for future style reference.",
      "TOOL_FIND_DESCRIPTION": "Search past writing samples to find relevant examples of the user's writing voice, tone, and style patterns. Use this when generating any text in the user's personal style."
    }
  }
}
