# Ghostwriter environment variables
#
# Most configuration is now managed via `gw config` and stored at
# ~/.config/ghostwriter/config.yaml. This file is primarily used by
# mcp-server-qdrant and as a fallback for the gw CLI.
#
# The gw CLI supports GW_-prefixed variable names (e.g., GW_GITHUB_USERNAME)
# as well as the legacy names below.

# GitHub configuration (legacy names, also accepted as GW_GITHUB_USERNAME etc.)
GITHUB_USERNAME=your-github-username
GITHUB_ORGS=your-org-1,your-org-2

# Qdrant configuration (legacy names, also accepted as GW_QDRANT_URL etc.)
QDRANT_URL=http://127.0.0.1:6333
COLLECTION_NAME=writing-samples

# MCP server (used by mcp-server-qdrant, not by the gw CLI)
TOOL_STORE_DESCRIPTION=Store a writing sample for future style reference.
TOOL_FIND_DESCRIPTION=Search past writing samples to find relevant examples of the user's writing voice, tone, and style patterns.
